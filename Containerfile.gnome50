# Builds the GNOME 50 testing image by layering on top of the GNOME 49 image.
# This keeps the GNOME 50 image always in sync with the 49 base and avoids
# duplicating the full build chain.

ARG BASE_IMAGE="ghcr.io/ublue-os/bluefin:lts-testing@sha256:674b308d6964075a442be3408a1b620daf3420503dacaa8d388f84ab55040fba"
FROM ${BASE_IMAGE}

COPY build_scripts/upgrade-gnome49-to-50.sh /usr/local/bin/upgrade-gnome49-to-50.sh

RUN chmod +x /usr/local/bin/upgrade-gnome49-to-50.sh && \
    /usr/local/bin/upgrade-gnome49-to-50.sh && \
    rm /usr/local/bin/upgrade-gnome49-to-50.sh
